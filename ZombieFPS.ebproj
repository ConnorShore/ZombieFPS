Project: ZombieFPS
EngineVersion: 0.1.0
SceneDirectory: GameData/Scenes
AssetDirectory: GameData/Assets
StartScene: Default.ebs
AssetFile: Assets.eba
Settings:
  General:
    ScenesInBuild: []
  Physics:
    GravityStrength: 9.81
    GravityVector: [0,-1,0]
    UpdateRate: 60
    PositionSolverIterations: 5
    VelocitySolverIterations: 10
    CollisionFilters:
      - Name: Environment
      - Name: VFX
      - Name: Player
      - Name: Enemy
  Render:
    RenderLayers:
      - Name: Default
